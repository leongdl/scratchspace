# syntax=docker/dockerfile:1
# ComfyUI Multi-Model Image: LTX-2.3 + Qwen-Image-Edit-2511 + Z-Image
# Layers on comfyui-rocky:latest (Rocky 9 + CUDA 12.6 + torch 2.7 + ComfyUI)
#
# Build:
#   docker build -f Dockerfile.multimodel \
#     --secret id=hf_token,src=.env.secret \
#     -t comfyui-multimodel:latest .
#
# .env.secret should contain just the raw token value (no key=value format).
# The secret is mounted at build time only and NEVER stored in image layers.

FROM comfyui-rocky:latest

USER root

# Install huggingface-hub for model downloads
RUN python3.12 -m pip install --upgrade pip huggingface-hub

# Create model directories
RUN mkdir -p \
    /opt/comfyui/models/checkpoints \
    /opt/comfyui/models/diffusion_models \
    /opt/comfyui/models/text_encoders \
    /opt/comfyui/models/vae \
    /opt/comfyui/models/loras \
    /opt/comfyui/models/latent_upscale_models

# Copy and run the download script with the secret token mounted
COPY download_models.py /tmp/download_models.py
RUN --mount=type=secret,id=hf_token \
    python3.12 /tmp/download_models.py && \
    rm /tmp/download_models.py

# =============================================================================
# Custom nodes
# =============================================================================

# ComfyUI-LTXVideo — LTXVideoSampler and related LTX nodes
RUN git clone https://github.com/Lightricks/ComfyUI-LTXVideo.git \
    /opt/comfyui/custom_nodes/ComfyUI-LTXVideo && \
    python3.12 -m pip install -r /opt/comfyui/custom_nodes/ComfyUI-LTXVideo/requirements.txt

# ComfyUI-VideoHelperSuite — VideoCombine node for video output
RUN git clone https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite.git \
    /opt/comfyui/custom_nodes/ComfyUI-VideoHelperSuite && \
    python3.12 -m pip install -r /opt/comfyui/custom_nodes/ComfyUI-VideoHelperSuite/requirements.txt

# ComfyUI-ZImagePowerNodes — ZImageLoader, ZSampler for Z-Image workflows
RUN git clone https://github.com/martin-rizzo/ComfyUI-ZImagePowerNodes.git \
    /opt/comfyui/custom_nodes/ComfyUI-ZImagePowerNodes

# Patch torch.AcceleratorError for torch < 2.8
# ComfyUI 0.16.4+ references torch.AcceleratorError which only exists in torch 2.8+
RUN sed -i "s/if isinstance(e, torch.AcceleratorError) and getattr(e, 'error_code', None) == 2:/if hasattr(torch, 'AcceleratorError') and isinstance(e, torch.AcceleratorError) and getattr(e, 'error_code', None) == 2:/" \
        /opt/comfyui/comfy/model_management.py && \
    sed -i "s/    except torch.AcceleratorError:/    except (torch.AcceleratorError if hasattr(torch, 'AcceleratorError') else RuntimeError):/" \
        /opt/comfyui/comfy/model_management.py

# Fix ownership
RUN chown -R comfyui:comfyui /opt/comfyui/models /opt/comfyui/custom_nodes

USER comfyui

EXPOSE 8188
CMD ["/start-comfyui.sh"]
